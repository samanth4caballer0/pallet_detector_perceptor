<?xml version="1.0"?>
<robot name="camera_stand">
  <!-- HERE WE TUNE THE PARAMETERS OF THE RGBD CAMERA TO MATCH THE D435F REALSENSE -->
  <!-- Mark as static in Gazebo (no physics needed, this changes later when simulating robot) -->
  <gazebo>
    <static>true</static>
  </gazebo>

  <!-- ==================== Links ==================== -->

  <!-- Base link at ground level (anchor for world -> base_link TF) -->
  <link name="base_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <!-- Stand body: 0.4 x 0.4 x 0.5 m dark-gray box -->
  <link name="stand_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.4 0.4 0.5"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.4 0.5"/>
      </geometry>
    </collision>
  </link>

  <!-- Camera body (D435f housing: 90mm wide x 25mm tall x 25mm deep) -->
  <link name="rgbd_camera_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.025 0.09 0.025"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
  </link>

  <!-- Depth optical frame (REP-103: Z forward, X right, Y down) -->
  <link name="rgbd_camera_optical_frame"/>

  <!-- RGB optical frame (15 mm lateral offset from depth) -->
  <link name="rgbd_camera_color_optical_frame"/>

  <!-- ==================== Joints ==================== -->

  <!-- base_link -> stand_link (center of 0.5 m box at z = 0.25) -->
  <joint name="base_to_stand" type="fixed">
    <parent link="base_link"/>
    <child link="stand_link"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
  </joint>

  <!-- stand_link -> rgbd_camera_link (camera mounted on top-front of stand) -->
  <joint name="stand_to_camera" type="fixed">
    <parent link="stand_link"/>
    <child link="rgbd_camera_link"/>
    <origin xyz="0.25 0 0.30" rpy="0 0 0"/>
  </joint>

  <!-- rgbd_camera_link -> depth optical frame (REP-103 rotation) -->
  <joint name="camera_to_depth_optical" type="fixed">
    <parent link="rgbd_camera_link"/>
    <child link="rgbd_camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
  </joint>

  <!-- rgbd_camera_link -> color optical frame (REP-103 rotation + 15 mm Y offset) -->
  <joint name="camera_to_color_optical" type="fixed">
    <parent link="rgbd_camera_link"/>
    <child link="rgbd_camera_color_optical_frame"/>
    <origin xyz="0 -0.015 0" rpy="-1.5707963 0 -1.5707963"/>
  </joint>

  <!-- ==================== Gazebo extensions ==================== -->

  <!-- Prevent fixed-joint lumping so each link exists in Gazebo -->
  <gazebo reference="base_to_stand">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="stand_to_camera">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="camera_to_depth_optical">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="camera_to_color_optical">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

  <gazebo reference="stand_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- D435f sensors on the camera link -->
  <gazebo reference="rgbd_camera_link">

    <!-- ===== Depth sensor (IR stereo) ===== -->
    <!-- FOV: 87deg x 58deg, Resolution: 1280x720, Range: 0.105m-10m -->
    <sensor name="d435f_depth" type="depth">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <always_on>true</always_on>
      <update_rate>30</update_rate>

      <camera>
        <horizontal_fov>1.518</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.105</near>
          <far>10.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.004</stddev>
        </noise>
      </camera>

      <plugin name="d435f_depth_plugin" filename="libgazebo_ros_depth_camera.so">
        <robotNamespace>/demo</robotNamespace>
        <cameraName>rgbd_camera</cameraName>
        <frameName>rgbd_camera_optical_frame</frameName>
        <depthImageTopicName>depth/image_raw</depthImageTopicName>
        <depthImageInfoTopicName>depth/camera_info</depthImageInfoTopicName>
        <pointCloudTopicName>depth/points</pointCloudTopicName>
        <imageTopicName>ir/image_raw</imageTopicName>
        <cameraInfoTopicName>ir/camera_info</cameraInfoTopicName>
        <pointCloudCutoff>0.105</pointCloudCutoff>
        <pointCloudCutoffMax>10.0</pointCloudCutoffMax>
      </plugin>
    </sensor>

    <!-- ===== RGB sensor ===== -->
    <!-- FOV: 69.4deg x 42.5deg, Resolution: 1920x1080 -->
    <!-- 15 mm lateral offset from depth origin (matches physical D435f layout) -->
    <sensor name="d435f_color" type="camera">
      <pose>0 -0.015 0 0 0 0</pose>
      <visualize>false</visualize>
      <always_on>true</always_on>
      <update_rate>30</update_rate>

      <camera>
        <horizontal_fov>1.211</horizontal_fov>
        <image>
          <width>1920</width>
          <height>1080</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.105</near>
          <far>10.0</far>
        </clip>
      </camera>

      <plugin name="d435f_color_plugin" filename="libgazebo_ros_camera.so">
        <robotNamespace>/demo/rgbd_camera</robotNamespace>
        <cameraName>rgb</cameraName>
        <frameName>rgbd_camera_color_optical_frame</frameName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
      </plugin>
    </sensor>

  </gazebo>

</robot>
